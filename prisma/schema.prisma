generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  displayName String
  credits     Float    @default(1000)
  isAdmin     Boolean  @default(false)
  createdAt   DateTime @default(now())
  orders      Order[]
}

model Product {
  id           String   @id @default(cuid())
  name         String
  symbol       String?
  atomicNumber Int?
  description  String
  price        Float
  imageUrl     String
  stock        Int      @default(0)
  createdAt    DateTime @default(now())
}

model Order {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  items           String   // JSON string of items: { productId, name, quantity, price }[]
  deliveryDetails String   // JSON string: { fullName, address, city, zipCode, country }
  totalAmount     Float
  status          String   @default("processing")
  createdAt       DateTime @default(now())
}
